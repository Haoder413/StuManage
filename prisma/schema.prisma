generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Workspace {
  id                String   @id
  name              String
  kind              String   @default("real")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  users             User[]
  students          Student[]
  courses           Course[]
  courseScheduleTimes CourseScheduleTime[]
  studentCourses    StudentCourse[]
  exams             Exam[]
  knowledgePoints   KnowledgePoint[]
  kpProgress        StudentKpProgress[]
  weakPoints        WeakPoint[]
  reviewSchedules   ReviewSchedule[]
  schedules         Schedule[]
  attendance        Attendance[]
  lessonHourLogs    LessonHourLog[]
  communicationLogs CommunicationLog[]
  weakPointTags     WeakPointTag[]
  lessonTags        LessonTag[]
  resources         LearningResource[]
  resourcePermissions ResourcePermission[]
  resourceCoursePermissions ResourceCoursePermission[]
  learningLinks     LearningLink[]
  parentScheduleItems ParentScheduleItem[]
  parentScheduleSubjects ParentScheduleSubject[]
}

model User {
  id           String   @id @default(cuid())
  workspaceId  String
  name         String
  phone        String?  @unique
  email        String?  @unique
  role         String
  teachingSubject String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  sessions     Session[]
  parentStudents ParentStudent[]
  learningLinksAsParent LearningLink[] @relation("ParentLearningLinks")
  learningLinksAsTeacher LearningLink[] @relation("TeacherLearningLinks")
  uploadedResources LearningResource[]
  resourcePermissions ResourcePermission[]
  parentScheduleItems ParentScheduleItem[]
  parentScheduleSubjects ParentScheduleSubject[]
}

model LearningLink {
  id          String   @id @default(cuid())
  workspaceId String  @default("default-real")
  parentId    String
  studentId   String
  teacherId   String
  courseId    String?
  subject     String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  parent      User      @relation("ParentLearningLinks", fields: [parentId], references: [id], onDelete: Cascade)
  teacher     User      @relation("TeacherLearningLinks", fields: [teacherId], references: [id], onDelete: Cascade)
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course      Course?   @relation(fields: [courseId], references: [id], onDelete: SetNull)
  attendance  Attendance[]
  exams       Exam[]
  kpProgress  StudentKpProgress[]
  weakPoints  WeakPoint[]
  parentScheduleItems ParentScheduleItem[]

  @@unique([parentId, studentId, teacherId, subject])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ParentStudent {
  id        String   @id @default(cuid())
  parentId  String
  studentId String
  createdAt DateTime @default(now())
  parent   User    @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student  Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
}

model Student {
  id               String   @id @default(cuid())
  workspaceId      String   @default("default-real")
  name             String
  grade            String?
  parentContact    String?
  enrollmentDate   DateTime @default(now())
  lessonFrequency  String?
  tuition          Float?
  totalLessonHours Int      @default(0)
  remainingLessonHours Int  @default(0)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  studentCourses   StudentCourse[]
  exams            Exam[]
  kpProgress       StudentKpProgress[]
  weakPoints       WeakPoint[]
  schedules        Schedule[]
  attendance       Attendance[]
  lessonHourLogs   LessonHourLog[]
  communicationLogs CommunicationLog[]
  parentLinks      ParentStudent[]
  learningLinks    LearningLink[]
  parentScheduleItems ParentScheduleItem[]
}

model Course {
  id              String   @id @default(cuid())
  workspaceId      String   @default("default-real")
  name            String
  description     String?
  type            String   @default("fixed")
  defaultCapacity Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  studentCourses  StudentCourse[]
  scheduleTimes   CourseScheduleTime[]
  schedules       Schedule[]
  knowledgePoints KnowledgePoint[]
  learningLinks   LearningLink[]
  resourcePermissions ResourceCoursePermission[]
}

model CourseScheduleTime {
  id          String   @id @default(cuid())
  workspaceId String   @default("default-real")
  courseId    String
  dayOfWeek   Int
  startTime   String
  endTime     String
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model StudentCourse {
  id            String   @id @default(cuid())
  workspaceId   String   @default("default-real")
  studentId     String
  courseId      String
  startDate     DateTime @default(now())
  status        String   @default("active")
  customContent String?
  createdAt     DateTime @default(now())
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Exam {
  id        String   @id @default(cuid())
  workspaceId String  @default("default-real")
  learningLinkId String?
  studentId String
  name      String
  type      String   // entrance | monthly | quiz
  score     Float
  totalScore Float  @default(100)
  date      DateTime @default(now())
  notes     String?
  reviewStatus String @default("approved")
  submittedById String?
  reviewedById String?
  reviewedAt DateTime?
  rejectionReason String?
  createdAt DateTime @default(now())
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  learningLink LearningLink? @relation(fields: [learningLinkId], references: [id], onDelete: SetNull)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model KnowledgePoint {
  id        String   @id @default(cuid())
  workspaceId String  @default("default-real")
  courseId  String
  name      String
  parentId  String?
  orderIndex Int     @default(0)
  createdAt DateTime @default(now())
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  course      Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  parent      KnowledgePoint?     @relation("Kptree", fields: [parentId], references: [id])
  children    KnowledgePoint[]    @relation("Kptree")
  studentProgress StudentKpProgress[]
}

model StudentKpProgress {
  id                String   @id @default(cuid())
  workspaceId       String   @default("default-real")
  learningLinkId    String?
  studentId         String
  knowledgePointId  String
  status            String   @default("not_started")
  masteredAt        DateTime?
  updatedAt         DateTime @updatedAt
  workspace       Workspace      @relation(fields: [workspaceId], references: [id])
  learningLink    LearningLink?  @relation(fields: [learningLinkId], references: [id], onDelete: SetNull)
  student         Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  knowledgePoint  KnowledgePoint  @relation(fields: [knowledgePointId], references: [id], onDelete: Cascade)
  @@unique([studentId, knowledgePointId, learningLinkId])
  @@unique([learningLinkId, knowledgePointId])
}

model WeakPoint {
  id                String   @id @default(cuid())
  workspaceId       String   @default("default-real")
  learningLinkId    String?
  studentId         String
  knowledgePointId  String?
  description       String
  status            String   @default("active")
  masteredAt        DateTime?
  createdAt         DateTime @default(now())
  workspace       Workspace       @relation(fields: [workspaceId], references: [id])
  learningLink    LearningLink?   @relation(fields: [learningLinkId], references: [id], onDelete: SetNull)
  student         Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  reviewSchedules ReviewSchedule[]
}

model ReviewSchedule {
  id             String    @id @default(cuid())
  workspaceId    String    @default("default-real")
  weakPointId    String
  stage          Int       @default(1)
  lastReviewedAt DateTime?
  nextReviewAt   DateTime
  status         String    @default("pending")
  createdAt      DateTime  @default(now())
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  weakPoint WeakPoint @relation(fields: [weakPointId], references: [id], onDelete: Cascade)
}

model Schedule {
  id          String   @id @default(cuid())
  workspaceId String   @default("default-real")
  studentId   String?
  courseId    String?
  type        String   // fixed | flexible
  dayOfWeek   Int?
  startTime   String?
  endTime     String?
  date        DateTime?
  startDate   DateTime?
  endDate     DateTime?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  student    Student?    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course     Course?     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  attendance Attendance[]
}

model Attendance {
  id         String   @id @default(cuid())
  workspaceId String  @default("default-real")
  learningLinkId String?
  scheduleId String
  studentId  String
  date       DateTime
  status     String   // present | absent | makeup
  notes      String?
  lessonContent String?
  lessonFeedback String?
  contentTags String?
  feedbackTags String?
  weakPointTags String?
  createdAt  DateTime @default(now())
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  learningLink LearningLink? @relation(fields: [learningLinkId], references: [id], onDelete: SetNull)
  schedule Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lessonHourLogs LessonHourLog[]
}

model LessonHourLog {
  id                   String   @id @default(cuid())
  workspaceId          String   @default("default-real")
  studentId            String
  attendanceId         String?
  type                 String
  deltaTotalHours      Int      @default(0)
  deltaRemainingHours  Int      @default(0)
  beforeTotalHours     Int
  afterTotalHours      Int
  beforeRemainingHours Int
  afterRemainingHours  Int
  note                 String?
  teacherFeedback      String?
  createdAt            DateTime @default(now())
  workspace            Workspace @relation(fields: [workspaceId], references: [id])
  student              Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  attendance           Attendance? @relation(fields: [attendanceId], references: [id], onDelete: SetNull)

  @@index([workspaceId, studentId, createdAt])
  @@index([attendanceId])
}

model ParentScheduleItem {
  id             String       @id @default(cuid())
  workspaceId    String       @default("default-real")
  parentId     String
  studentId    String
  learningLinkId String?
  seriesId       String?
  iconKey        String       @default("other")
  subjectLabel   String       @default("其他")
  seriesEndDate  DateTime?
  repeatDays     String?
  title          String
  date           DateTime
  startTime      String
  endTime        String
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  workspace      Workspace    @relation(fields: [workspaceId], references: [id])
  parent         User         @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  learningLink   LearningLink? @relation(fields: [learningLinkId], references: [id], onDelete: SetNull)

  @@index([workspaceId, parentId, date])
  @@index([workspaceId, studentId, date])
  @@index([workspaceId, parentId, seriesId])
}

model ParentScheduleSubject {
  id          String    @id @default(cuid())
  workspaceId String    @default("default-real")
  parentId    String
  name        String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  parent      User      @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, parentId, name])
  @@index([workspaceId, parentId, isActive])
}

model CommunicationLog {
  id        String   @id @default(cuid())
  workspaceId String  @default("default-real")
  studentId String
  date      DateTime @default(now())
  method    String   // phone | wechat | in_person
  content   String
  createdAt DateTime @default(now())
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model WeakPointTag {
  id        String   @id @default(cuid())
  workspaceId String  @default("default-real")
  name      String
  category  String?
  createdAt DateTime @default(now())
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, name])
}

model LessonTag {
  id        String   @id @default(cuid())
  workspaceId String  @default("default-real")
  name      String
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, name, type])
}

model LearningResource {
  id          String   @id @default(cuid())
  workspaceId String  @default("default-real")
  title       String
  description String?
  type        String
  subject     String?
  resourceKind String @default("paper")
  fileName    String
  storedName  String
  mimeType    String
  extension   String
  size        Int
  grade       String?
  courseId    String?
  keywords    String?
  uploadedById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  uploadedBy  User      @relation(fields: [uploadedById], references: [id])
  permissions ResourcePermission[]
  coursePermissions ResourceCoursePermission[]
}

model ResourceCoursePermission {
  id          String   @id @default(cuid())
  workspaceId String  @default("default-real")
  resourceId  String
  courseId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workspace   Workspace        @relation(fields: [workspaceId], references: [id])
  resource    LearningResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([resourceId, courseId])
}

model ResourcePermission {
  id          String   @id @default(cuid())
  workspaceId String  @default("default-real")
  resourceId  String
  userId      String
  canPreview  Boolean  @default(false)
  canDownload Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workspace   Workspace        @relation(fields: [workspaceId], references: [id])
  resource    LearningResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([resourceId, userId])
}
