<view class="page">
  <view class="header">
    <view class="title">孩子首页</view>
    <view class="subtitle">课程、课时、最近上课和成绩概览</view>
  </view>

  <view wx:if="{{loading}}" class="card muted">加载中...</view>
  <view wx:elif="{{students.length === 0}}" class="card muted">暂无绑定学生</view>

  <block wx:for="{{students}}" wx:key="id">
    <view class="card">
      <view class="student-name">{{item.name}}</view>
      <view class="subtitle">{{item.grade || '未填写年级'}}</view>
      <view class="stats">
        <view class="stat">
          <view class="stat-value">{{item.remainingLessonHours}}</view>
          <view class="stat-label">剩余课时</view>
        </view>
        <view class="stat">
          <view class="stat-value">{{item.weakPointCount}}</view>
          <view class="stat-label">当前薄弱点</view>
        </view>
      </view>
      <view class="section-title">所属课程</view>
      <view>
        <text wx:for="{{item.courses}}" wx:key="id" class="pill">{{item.name}}</text>
        <text wx:if="{{item.courses.length === 0}}" class="muted">暂无课程</text>
      </view>
    </view>

    <view class="card">
      <view class="section-title">最近成绩</view>
      <view wx:if="{{item.latestExams.length === 0}}" class="muted">暂无成绩</view>
      <view wx:for="{{item.latestExams}}" wx:key="id" wx:for-item="exam" class="list-row">
        <view>
          <view class="row-title">{{exam.name}}</view>
          <view class="row-sub">{{exam.typeLabel}} · {{exam.dateText}}</view>
        </view>
        <view class="score">{{exam.percent}}%</view>
      </view>
    </view>

    <view class="card">
      <view class="section-title">最近上课</view>
      <view wx:if="{{item.latestLessons.length === 0}}" class="muted">暂无上课记录</view>
      <view wx:for="{{item.latestLessons}}" wx:key="id" wx:for-item="lesson" class="list-row vertical-row">
        <view class="row-title">{{lesson.dateText}} · {{lesson.statusLabel}}</view>
        <view class="row-sub">内容：{{lesson.lessonContent || '待老师填写'}}</view>
        <view class="row-sub">反馈：{{lesson.lessonFeedback || '待老师填写'}}</view>
      </view>
    </view>
  </block>
</view>
