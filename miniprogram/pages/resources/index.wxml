<view class="page">
  <view class="header">
    <view class="title">资料中心</view>
    <view class="subtitle">查看老师授权的学习资料</view>
  </view>

  <view wx:if="{{loading}}" class="card muted">加载中...</view>
  <view wx:elif="{{resources.length === 0}}" class="card muted">暂无可查看资料</view>

  <view wx:for="{{resources}}" wx:key="id" class="card">
    <view class="resource-title">{{item.title}}</view>
    <view class="subtitle">{{item.grade || '未设置年级'}} · {{item.subject || '未设置科目'}} · {{item.kindText}}</view>
    <view class="description">{{item.description || item.fileName}}</view>
    <view class="resource-actions">
      <button wx:if="{{item.canPreview}}" size="mini" bindtap="preview" data-url="{{item.previewUrl}}">预览</button>
      <button wx:if="{{item.canDownload}}" size="mini" bindtap="download" data-url="{{item.downloadUrl}}">下载</button>
      <text wx:if="{{!item.canPreview && !item.canDownload}}" class="muted">暂无文件权限</text>
    </view>
  </view>
</view>
