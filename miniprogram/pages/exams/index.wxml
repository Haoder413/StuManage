<view class="page">
  <view class="header">
    <view class="title">成绩记录</view>
    <view class="subtitle">查看正式考试和随堂小测</view>
  </view>

  <view wx:if="{{loading}}" class="card muted">加载中...</view>
  <view wx:elif="{{students.length === 0}}" class="card muted">暂无成绩数据</view>

  <block wx:for="{{students}}" wx:key="id">
    <view class="card">
      <view class="student-row">
        <view>
          <view class="student-name">{{item.name}}</view>
          <view class="subtitle">{{item.examCount}} 次成绩</view>
        </view>
        <view class="average">{{item.averageText}}</view>
      </view>
      <view class="chart-card">
        <view class="chart-head">
          <view class="trend-label">成绩趋势</view>
          <view class="row-sub">按考试时间</view>
        </view>
        <canvas wx:if="{{item.chartPoints.length > 0}}" id="exam-chart-{{index}}" type="2d" class="chart-canvas"></canvas>
        <view wx:else class="chart-empty">暂无趋势数据</view>
      </view>
      <view wx:if="{{item.exams.length === 0}}" class="muted empty">暂无成绩记录</view>
      <view wx:for="{{item.exams}}" wx:key="id" wx:for-item="exam" class="exam-row">
        <view>
          <view class="row-title">{{exam.name}}</view>
          <view class="row-sub">{{exam.typeLabel}} · {{exam.dateText}}</view>
        </view>
        <view class="score-box">
          <view class="score">{{exam.score}}/{{exam.totalScore}}</view>
          <view class="percent">{{exam.percent}}%</view>
        </view>
      </view>
    </view>
  </block>
</view>
