.header {
  margin-bottom: 28rpx;
}

.student-row,
.exam-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.student-name {
  font-size: 34rpx;
  font-weight: 800;
}

.average {
  color: #0284c7;
  font-size: 40rpx;
  font-weight: 800;
}

.chart-card {
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: #f8fafc;
}

.chart-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.trend-label {
  color: #0f172a;
  font-size: 26rpx;
  font-weight: 800;
}

.chart-canvas {
  width: 100%;
  height: 320rpx;
}

.chart-empty {
  padding: 72rpx 0;
  color: #94a3b8;
  font-size: 24rpx;
  text-align: center;
}

.exam-row {
  padding: 22rpx 0;
  border-top: 1rpx solid #f1f5f9;
}

.row-title {
  font-size: 28rpx;
  font-weight: 700;
}

.row-sub,
.percent {
  color: #64748b;
  font-size: 24rpx;
}

.score-box {
  text-align: right;
}

.score {
  font-size: 28rpx;
  font-weight: 800;
}

.empty {
  margin-top: 24rpx;
}
