.header {
  margin-bottom: 28rpx;
}

.homework-card {
  padding-bottom: 10rpx;
}

.card-head,
.history-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.homework-title {
  color: #0f172a;
  font-size: 32rpx;
  font-weight: 800;
}

.status {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #e0f2fe;
  color: #0369a1;
  font-size: 24rpx;
  font-weight: 800;
}

.meta,
.row-sub,
.comment {
  color: #64748b;
  font-size: 24rpx;
}

.meta,
.description {
  margin-top: 14rpx;
}

.description {
  color: #334155;
  font-size: 26rpx;
  line-height: 1.7;
}

.actions {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}

.compact-actions {
  margin-top: 12rpx;
}

.primary-mini {
  background: #0284c7;
  color: #ffffff;
}

.current,
.review,
.history {
  margin-top: 24rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #f1f5f9;
}

.section-title {
  margin-bottom: 12rpx;
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 800;
}

.total-score {
  color: #0284c7;
  font-size: 34rpx;
  font-weight: 900;
}

.review-row,
.history-row {
  padding: 16rpx 0;
  border-top: 1rpx solid #f8fafc;
}

.row-title {
  font-size: 26rpx;
  font-weight: 700;
}
