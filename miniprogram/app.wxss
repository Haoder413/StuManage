page {
  background: #f8fafc;
  color: #0f172a;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx;
}

.card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(15, 23, 42, 0.06);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #0f172a;
}

.subtitle {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #64748b;
}

.muted {
  color: #94a3b8;
}

.pill {
  display: inline-flex;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #e0f2fe;
  color: #0369a1;
  font-size: 24rpx;
  font-weight: 600;
}

.button {
  border-radius: 16rpx;
  background: #0284c7;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}
